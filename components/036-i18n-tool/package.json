{
  "name": "036-i18n-tool",
  "version": "1.0.0",
  "description": "A comprehensive internationalization (i18n) toolkit for TypeScript",
  "main": "dist/i18n.js",
  "types": "dist/i18n.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "ts-node src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "pluralization",
    "formatting"
  ],
  "author": "Jules",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
